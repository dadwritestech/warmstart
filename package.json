    "cross-spawn": "^7.0.3",
    "smol-toml": "^1.3.0",
    "yaml": "^2.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
